rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ========== Helpers ==========

    function isAuth() {
      return request.auth != null;
    }

    function isLawyer() {
      return isAuth() && exists(/databases/$(database)/documents/lawyers/$(request.auth.uid));
    }

    function isOwner(clientId) {
      return isAuth() && request.auth.uid == clientId;
    }

    function isDocSizeValid() {
      return request.writeSize <= 524288;
    }

    function isValidClientCreate() {
      return request.resource.data.keys().hasAll(['name', 'phone'])
             && request.resource.data.name is string
             && request.resource.data.phone is string
             && isDocSizeValid();
    }

    function isValidInquiryCreate() {
      return request.resource.data.keys().hasAll(['name', 'phone', 'text'])
             && request.resource.data.name is string
             && request.resource.data.phone is string
             && request.resource.data.text is string
             && request.resource.data.status == 'new'
             && isDocSizeValid();
    }

    // ========== Clients collection ==========
    match /clients/{clientId} {
      allow read: if isLawyer() || isOwner(clientId);
      allow create: if isLawyer() && isDocSizeValid();
      allow update: if (isLawyer() || isOwner(clientId))
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'phone', 'updatedAt'])
                      && isDocSizeValid();
      allow delete: if isLawyer();
    }

    // ========== Sub-collections under a client ==========

    match /clients/{clientId}/cases/{caseId} {
      allow read, delete: if isLawyer() || isOwner(clientId);
      allow create, update: if (isLawyer() || isOwner(clientId)) && isDocSizeValid();
    }

    match /clients/{clientId}/cases/{caseId}/events/{eventId} {
      allow read, delete: if isLawyer() || isOwner(clientId);
      allow create, update: if (isLawyer() || isOwner(clientId)) && isDocSizeValid();
    }

    match /clients/{clientId}/cases/{caseId}/documents/{documentId} {
      allow read, delete: if isLawyer() || isOwner(clientId);
      allow create, update: if (isLawyer() || isOwner(clientId)) && isDocSizeValid();
    }

    match /clients/{clientId}/invoices/{invoiceId} {
      allow read: if isLawyer() || isOwner(clientId);
      allow create, update: if isLawyer() && isDocSizeValid();
      allow delete: if isLawyer();
    }

    match /clients/{clientId}/inspections/{inspectionId} {
      allow read, delete: if isLawyer() || isOwner(clientId);
      allow create, update: if (isLawyer() || isOwner(clientId)) && isDocSizeValid();
    }

    match /clients/{clientId}/messages/{messageId} {
      allow read, delete: if isLawyer() || isOwner(clientId);
      allow create, update: if (isLawyer() || isOwner(clientId)) && isDocSizeValid();
    }

    // ========== Inquiries collection (public write, admin read) ==========
    match /inquiries/{inquiryId} {
      allow create: if isValidInquiryCreate();
      allow read, update: if isLawyer() && isDocSizeValid();
      allow delete: if false;
    }

    // ========== Lawyers collection ==========
    match /lawyers/{lawyerId} {
      allow read: if isLawyer();
      allow write: if false;
    }
  }
}
