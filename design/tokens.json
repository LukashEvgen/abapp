{
  "meta": {
    "name": "LexTrack Design Tokens",
    "version": "3.0.0",
    "platform": "react-native",
    "colorScheme": "light",
    "source": "Lukashenko Yevhen — business-card brand sheet (Pantone 7459 C teal + Pantone 444 C grey)"
  },
  "colors": {
    "brand": {
      "primary":       "#2A8FA8",
      "primaryLight":  "#4FA9BF",
      "primaryDark":   "#1F6F84",
      "primaryMuted":  "rgba(42,143,168,0.12)",
      "primaryHover":  "rgba(42,143,168,0.06)",
      "secondary":      "#7C8084",
      "secondaryLight": "#9DA1A4",
      "secondaryDark":  "#5C6164",
      "secondaryMuted": "rgba(124,128,132,0.12)"
    },
    "semantic": {
      "success":      "#4A9B6E",
      "successLight": "#6EB48C",
      "successDark":  "#366E4F",
      "successBg":    "rgba(74,155,110,0.10)",
      "warning":      "#C28B3C",
      "warningLight": "#D4A865",
      "warningDark":  "#8C622A",
      "warningBg":    "rgba(194,139,60,0.10)",
      "danger":       "#B84545",
      "dangerLight":  "#CF6E6E",
      "dangerDark":   "#8A3232",
      "dangerBg":     "rgba(184,69,69,0.10)",
      "info":         "#3D7AA8",
      "infoLight":    "#6595BD",
      "infoDark":     "#2A567A",
      "infoBg":       "rgba(61,122,168,0.10)"
    },
    "neutral": {
      "0":    "#FFFFFF",
      "50":   "#F8F9FA",
      "100":  "#F1F3F4",
      "200":  "#E4E7E9",
      "300":  "#C9CDD0",
      "400":  "#9DA1A4",
      "500":  "#7C8084",
      "600":  "#5C6164",
      "700":  "#424649",
      "800":  "#2C2F31",
      "900":  "#1B1D1F",
      "1000": "#0F1011"
    },
    "surface": {
      "bg":      "#FFFFFF",
      "base":    "#F8F9FA",
      "raised":  "#FFFFFF",
      "sunken":  "#F1F3F4",
      "overlay": "rgba(15,16,17,0.40)",
      "inverse": "#1B1D1F"
    },
    "border": {
      "subtle":  "#E4E7E9",
      "default": "#C9CDD0",
      "strong":  "#9DA1A4"
    },
    "text": {
      "primary":   "#1B1D1F",
      "secondary": "#5C6164",
      "tertiary":  "#7C8084",
      "disabled":  "#9DA1A4",
      "inverse":   "#FFFFFF",
      "accent":    "#2A8FA8",
      "link":      "#3D7AA8"
    }
  },
  "spacing": {
    "unit": 4,
    "scale": { "0": 0, "1": 4, "2": 8, "3": 12, "4": 16, "5": 20, "6": 24, "7": 32, "8": 40, "9": 48, "10": 64 },
    "alias": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "2xl": 48 }
  },
  "radius": { "none": 0, "sm": 6, "md": 10, "lg": 16, "xl": 24, "full": 9999 },
  "shadows": {
    "0": { "android": { "elevation": 0 }, "ios": { "shadowColor": "#0F1011", "shadowOffset": { "width": 0, "height": 0 }, "shadowOpacity": 0, "shadowRadius": 0 } },
    "1": { "android": { "elevation": 1 }, "ios": { "shadowColor": "#0F1011", "shadowOffset": { "width": 0, "height": 1 }, "shadowOpacity": 0.06, "shadowRadius": 2 } },
    "2": { "android": { "elevation": 3 }, "ios": { "shadowColor": "#0F1011", "shadowOffset": { "width": 0, "height": 2 }, "shadowOpacity": 0.08, "shadowRadius": 6 } },
    "3": { "android": { "elevation": 8 }, "ios": { "shadowColor": "#0F1011", "shadowOffset": { "width": 0, "height": 8 }, "shadowOpacity": 0.10, "shadowRadius": 24 } }
  },
  "typography": {
    "family": { "sans": "System", "mono": "monospace" },
    "weight": { "regular": "400", "medium": "500", "semibold": "600", "bold": "700", "black": "800" },
    "size": { "xs": 11, "sm": 12, "base": 14, "md": 16, "lg": 18, "xl": 22, "2xl": 28, "3xl": 34 },
    "lineHeight": { "tight": 1.2, "snug": 1.3, "normal": 1.5, "relaxed": 1.625 },
    "letterSpacing": { "tight": -0.3, "normal": 0, "wide": 0.5, "wider": 1.2 }
  }
}
