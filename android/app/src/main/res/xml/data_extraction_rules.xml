<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- LexTrack — юридичний додаток. Забороняємо cloud backup (GDPR/конфіденційність). -->
    <cloud-backup>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <!-- Локальний device-to-device перенос теж заборонено для юридичних даних -->
    <device-transfer>
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
