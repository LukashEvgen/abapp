{
  "name": "lextrack",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest --coverage",
    "test:rules": "jest --testPathPattern=tests/firestore-storage.rules.test.js --no-coverage"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "js",
      "jsx",
      "json"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|date-fns|@firebase|firebase)/)"
    ],
    "collectCoverageFrom": [
      "src/utils/helpers.js",
      "src/utils/theme.js",
      "src/context/AuthContext.js"
    ],
    "coverageThreshold": {
      "src/utils/helpers.js": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "@react-native-firebase/app": "^19.0.0",
    "@react-native-firebase/app-check": "^19.3.0",
    "@react-native-firebase/auth": "^19.0.0",
    "@react-native-firebase/firestore": "^19.0.0",
    "@react-native-firebase/functions": "^19.0.0",
    "@react-native-firebase/messaging": "^19.0.0",
    "@react-native-firebase/storage": "^19.0.0",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@tanstack/react-query": "^5.40.0",
    "@testing-library/react-native": "^13.3.3",
    "date-fns": "^3.6.0",
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-blob-util": "^0.19.9",
    "react-native-document-picker": "^9.1.1",
    "react-native-gesture-handler": "^2.16.0",
    "react-native-image-picker": "^7.1.2",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-pdf": "^6.7.5",
    "react-native-reanimated": "^3.8.0",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "^3.30.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-webview": "^13.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/runtime": "^7.24.0",
    "@firebase/database-compat": "^2.1.3",
    "@firebase/firestore-compat": "^0.4.8",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@firebase/storage-compat": "^0.4.2",
    "@react-native/babel-preset": "0.73.21",
    "@react-native/eslint-config": "0.73.2",
    "@react-native/metro-config": "0.73.5",
    "@react-native/typescript-config": "0.73.1",
    "@types/react": "^18.2.75",
    "@types/react-test-renderer": "^18.0.7",
    "babel-jest": "^29.7.0",
    "eslint": "^8.57.0",
    "firebase": "^12.12.1",
    "firebase-tools": "^13.35.1",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.73.10",
    "prettier": "2.8.8",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18"
  }
}
